# Optional: override base images if Docker Hub is unavailable
PYTHON_IMAGE=python:3.11-slim
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:1.27-alpine

# Comma-separated CORS allowlist for backend
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Database connection string for backend
DATABASE_URL=sqlite:///./kanban.db
